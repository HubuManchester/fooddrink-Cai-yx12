<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:converters="clr-namespace:RecipeRandomizer.Converters"
             x:Class="RecipeRandomizer.Views.MainPage"
             Title="Recipe Book"
             x:Name="MainPageRoot">

    <ContentPage.Resources>
        <converters:FavoriteConverter x:Key="FavoriteConverter"/>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto, Auto, Auto, Auto, Auto, *">

        <!-- 标题栏 + 设置按钮 -->
        <Grid Grid.Row="0" ColumnDefinitions="*, Auto" Padding="10,15,10,10">
            <Label Grid.Column="0"
                   Text="🍽️ Random Recipe"
                   FontSize="22"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"
                   VerticalOptions="Center"/>
            <Button Grid.Column="1"
                    x:Name="SettingsButton"
                    Text="⚙️"
                    BackgroundColor="Transparent"
                    TextColor="#FF6B35"
                    FontSize="24"
                    WidthRequest="50"
                    HeightRequest="50"
                    VerticalOptions="Center"
                    HorizontalOptions="Center"/>
        </Grid>

        <!-- 搜索框 -->
        <SearchBar x:Name="SearchBar"
                   Grid.Row="1"
                   Margin="15,5,15,0"
                   Placeholder="Search recipes..."
                   BackgroundColor="White"
                   CancelButtonColor="Gray"/>

        <!-- 分类筛选 -->
        <HorizontalStackLayout Grid.Row="2" Padding="15" Spacing="10" Margin="0,5,0,0">
            <Label Text="Category:"
                   VerticalTextAlignment="Center"
                   FontSize="14"/>
            <Picker x:Name="CategoryPicker"
                    Title="All"
                    WidthRequest="130"
                    BackgroundColor="White"
                    FontSize="12"
                    VerticalOptions="Center"/>
            <Button x:Name="FilterButton"
                    Text="Filter"
                    BackgroundColor="#FF6B35"
                    TextColor="White"
                    HeightRequest="40"
                    FontSize="13"
                    VerticalOptions="Center"
                    HorizontalOptions="Center"/>
        </HorizontalStackLayout>

        <!-- 随机和收藏按钮 -->
        <Grid Grid.Row="3"
              ColumnDefinitions="*,*"
              ColumnSpacing="10"
              Padding="15,0,15,10">
            <Button x:Name="RandomButton"
                    Text="🎲 Random"
                    BackgroundColor="#4CAF50"
                    TextColor="White"
                    CornerRadius="15"
                    FontAttributes="Bold"
                    HeightRequest="45"
                    VerticalOptions="Center"/>
            <Button x:Name="FavoritesButton"
                    Grid.Column="1"
                    Text="⭐ Favorites"
                    BackgroundColor="#FF9800"
                    TextColor="White"
                    CornerRadius="15"
                    FontAttributes="Bold"
                    HeightRequest="45"
                    VerticalOptions="Center"/>
        </Grid>

        <!-- 添加食谱按钮 -->
        <Frame x:Name="AddFrame"
               Grid.Row="4"
               Margin="15,5,15,5"
               Padding="12,8"
               BackgroundColor="#E8F5E9"
               CornerRadius="10">
            <Label Text="➕  Add New Recipe"
                   TextColor="#2E7D32"
                   FontSize="15"
                   FontAttributes="Bold"
                   VerticalOptions="Center"
                   HorizontalOptions="Center"/>
            <Frame.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnAddTapped"/>
            </Frame.GestureRecognizers>
        </Frame>

        <!-- 下拉刷新 + 食谱列表 -->
        <RefreshView x:Name="RefreshView"
                     Grid.Row="5"
                     IsRefreshing="{Binding IsRefreshing, Mode=TwoWay}"
                     RefreshColor="#FF6B35">
            <CollectionView x:Name="RecipesCollectionView"
                            SelectionMode="None"
                            Margin="0,5,0,0">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame Padding="12,8"
                               Margin="10,4"
                               BackgroundColor="{Binding ItemBackgroundColor}"
                               CornerRadius="12">
                            <Frame.GestureRecognizers>
                                <TapGestureRecognizer 
                                    CommandParameter="{Binding .}"
                                    Tapped="OnRecipeTapped"/>
                            </Frame.GestureRecognizers>
                            <Grid ColumnDefinitions="*,Auto">
                                <VerticalStackLayout>
                                    <Label Text="{Binding Name}"
                                           FontSize="{Binding NameFontSize}"
                                           FontAttributes="Bold"
                                           LineBreakMode="TailTruncation"
                                           TextColor="{Binding ItemTextColor}"/>
                                    <Label Text="{Binding Category}"
                                           FontSize="{Binding CategoryFontSize}"
                                           TextColor="{Binding CategoryTextColor}"/>
                                    <Label Text="{Binding PrepTime, StringFormat='⏱️ {0} min'}"
                                           FontSize="{Binding TimeFontSize}"
                                           TextColor="#FF6B35"/>
                                </VerticalStackLayout>
                                <Label Grid.Column="1"
                                       Text="{Binding IsFavorite, Converter={StaticResource FavoriteConverter}}"
                                       FontSize="20"
                                       VerticalTextAlignment="Center"
                                       HorizontalTextAlignment="Center"/>
                            </Grid>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>

    </Grid>
</ContentPage>