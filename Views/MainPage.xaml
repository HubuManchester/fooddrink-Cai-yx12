<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:converters="clr-namespace:RecipeRandomizer.Converters"
             x:Class="RecipeRandomizer.Views.MainPage"
             Title="Recipe Book"
             x:Name="MainPageRoot">

    <ContentPage.Resources>
        <converters:FavoriteConverter x:Key="FavoriteConverter"/>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto, Auto, Auto, Auto, Auto, Auto, Auto, *">

        <VerticalStackLayout Grid.Row="0" Padding="10,10,10,0" Spacing="2">
            <Label Text="🍽️ Random Recipe"
                   FontSize="22"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"/>
            <Label Text="Discover &amp; Share Delicious Recipes"
                   FontSize="12"
                   TextColor="Gray"
                   HorizontalOptions="Center"/>
        </VerticalStackLayout>

        <HorizontalStackLayout Grid.Row="1" 
                               Spacing="15" 
                               HorizontalOptions="Center"
                               Padding="10,0">
            <Button x:Name="MapButton"
                    Text="🗺️ Map"
                    BackgroundColor="Transparent"
                    TextColor="#FF6B35"
                    FontSize="14"
                    FontAttributes="Bold"/>
            <Button x:Name="SettingsButton"
                    Text="⚙️ Settings"
                    BackgroundColor="Transparent"
                    TextColor="#FF6B35"
                    FontSize="14"
                    FontAttributes="Bold"/>
        </HorizontalStackLayout>

        <SearchBar x:Name="SearchBar"
                   Grid.Row="2"
                   Margin="15,5,15,0"
                   Placeholder="Search recipes..."
                   BackgroundColor="White"
                   CancelButtonColor="Gray"/>

        <Frame x:Name="DailyRecommendationFrame"
               Grid.Row="3"
               Margin="15,5,15,0"
               Padding="15,10"
               BackgroundColor="#FFF3E0"
               CornerRadius="15">
            <Grid ColumnDefinitions="Auto, *">
                <Label Text="🌟" FontSize="30" VerticalTextAlignment="Center"/>
                <VerticalStackLayout Grid.Column="1" Margin="10,0,0,0">
                    <Label Text="Today's Recommendation" 
                           FontSize="12" 
                           TextColor="#FF6B35"
                           FontAttributes="Bold"/>
                    <Label x:Name="DailyRecommendationLabel"
                           Text="Loading..."
                           FontSize="16"
                           FontAttributes="Bold"
                           LineBreakMode="TailTruncation"/>
                </VerticalStackLayout>
            </Grid>
            <Frame.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnDailyRecommendationTapped"/>
            </Frame.GestureRecognizers>
        </Frame>

        <HorizontalStackLayout Grid.Row="4" 
                               Padding="15" 
                               Spacing="10" 
                               Margin="0,0,0,0">
            <Label Text="Category:"
                   VerticalTextAlignment="Center"
                   FontSize="14"/>
            <Picker x:Name="CategoryPicker"
                    Title="All"
                    WidthRequest="130"
                    BackgroundColor="White"
                    FontSize="12"
                    VerticalOptions="Center"/>
            <Button x:Name="FilterButton"
                    Text="Filter"
                    BackgroundColor="#FF6B35"
                    TextColor="White"
                    HeightRequest="40"
                    FontSize="13"
                    VerticalOptions="Center"
                    HorizontalOptions="Center"/>
        </HorizontalStackLayout>

        <Grid Grid.Row="5"
              ColumnDefinitions="*,*"
              ColumnSpacing="10"
              Padding="15,0,15,10">
            <Button x:Name="RandomButton"
                    Text="🎲 Random"
                    BackgroundColor="#4CAF50"
                    TextColor="White"
                    CornerRadius="15"
                    FontAttributes="Bold"
                    HeightRequest="45"
                    VerticalOptions="Center"/>
            <Button x:Name="FavoritesButton"
                    Grid.Column="1"
                    Text="⭐ Favorites"
                    BackgroundColor="#FF9800"
                    TextColor="White"
                    CornerRadius="15"
                    FontAttributes="Bold"
                    HeightRequest="45"
                    VerticalOptions="Center"/>
        </Grid>

        <Frame x:Name="AddFrame"
               Grid.Row="6"
               Margin="15,5,15,5"
               Padding="12,8"
               BackgroundColor="#E8F5E9"
               CornerRadius="10">
            <Label Text="➕  Add New Recipe"
                   TextColor="#2E7D32"
                   FontSize="15"
                   FontAttributes="Bold"
                   VerticalOptions="Center"
                   HorizontalOptions="Center"/>
            <Frame.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnAddTapped"/>
            </Frame.GestureRecognizers>
        </Frame>

        <RefreshView x:Name="RefreshView"
                     Grid.Row="7"
                     IsRefreshing="{Binding IsRefreshing, Mode=TwoWay}"
                     RefreshColor="#FF6B35">
            <CollectionView x:Name="RecipesCollectionView"
                            SelectionMode="None"
                            Margin="0,5,0,0">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame Padding="12,8"
                               Margin="10,4"
                               BackgroundColor="{Binding ItemBackgroundColor}"
                               CornerRadius="12">
                            <Frame.GestureRecognizers>
                                <TapGestureRecognizer 
                                    CommandParameter="{Binding .}"
                                    Tapped="OnRecipeTapped"/>
                            </Frame.GestureRecognizers>
                            <Grid ColumnDefinitions="*,Auto">
                                <VerticalStackLayout>
                                    <Label Text="{Binding Name}"
                                           FontSize="{Binding NameFontSize}"
                                           FontAttributes="Bold"
                                           LineBreakMode="TailTruncation"
                                           TextColor="{Binding ItemTextColor}"/>
                                    <Label Text="{Binding Category}"
                                           FontSize="{Binding CategoryFontSize}"
                                           TextColor="{Binding CategoryTextColor}"/>
                                    <Label Text="{Binding PrepTime, StringFormat='⏱️ {0} min'}"
                                           FontSize="{Binding TimeFontSize}"
                                           TextColor="#FF6B35"/>
                                </VerticalStackLayout>
                                <Label Grid.Column="1"
                                       Text="{Binding IsFavorite, Converter={StaticResource FavoriteConverter}}"
                                       FontSize="20"
                                       VerticalTextAlignment="Center"
                                       HorizontalTextAlignment="Center"/>
                            </Grid>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>

    </Grid>
</ContentPage>