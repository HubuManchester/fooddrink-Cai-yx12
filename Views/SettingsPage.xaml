<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="RecipeRandomizer.Views.SettingsPage"
             Title="Settings"
             BackgroundColor="#F5F5F5">

    <VerticalStackLayout Padding="20" Spacing="20">

        <Label x:Name="TitleLabel"
               Text="⚙️ Settings"
               FontSize="24"
               FontAttributes="Bold"
               HorizontalOptions="Center"/>

        <Frame Padding="15" BackgroundColor="White">
            <VerticalStackLayout Spacing="15">

                <Label x:Name="AccessibilityLabel"
                       Text="🔧 Accessibility"
                       FontSize="16"
                       FontAttributes="Bold"
                       TextColor="#FF6B35"/>

                <Grid ColumnDefinitions="*, Auto">
                    <VerticalStackLayout>
                        <Label x:Name="LargeTextLabel"
                               Text="🔤 Large Text Mode"
                               FontSize="14"
                               FontAttributes="Bold"/>
                        <Label Text="Increase text size"
                               FontSize="11"
                               TextColor="Gray"/>
                    </VerticalStackLayout>
                    <Switch x:Name="LargeTextSwitch"
                            Grid.Column="1"
                            VerticalOptions="Center"/>
                </Grid>

                <BoxView HeightRequest="1" Color="#E0E0E0"/>

                <Grid ColumnDefinitions="*, Auto">
                    <VerticalStackLayout>
                        <Label x:Name="DarkModeLabel"
                               Text="🌙 Dark Mode"
                               FontSize="14"
                               FontAttributes="Bold"/>
                        <Label Text="Switch to dark theme"
                               FontSize="11"
                               TextColor="Gray"/>
                    </VerticalStackLayout>
                    <Switch x:Name="DarkModeSwitch"
                            Grid.Column="1"
                            VerticalOptions="Center"/>
                </Grid>

            </VerticalStackLayout>
        </Frame>

        <Frame Padding="15" BackgroundColor="White">
            <VerticalStackLayout Spacing="10">
                <Label x:Name="AboutLabel"
                       Text="📱 About"
                       FontSize="16"
                       FontAttributes="Bold"
                       TextColor="#FF6B35"/>
                <Label x:Name="AppNameLabel"
                       Text="Random Recipe Recommender"
                       FontSize="14"
                       FontAttributes="Bold"/>
                <Label x:Name="VersionLabel"
                       Text="Version 1.0"
                       FontSize="12"
                       TextColor="Gray"/>
                <Label x:Name="DescLabel"
                       Text="A .NET MAUI app for discovering recipes"
                       FontSize="12"
                       TextColor="Gray"
                       LineBreakMode="WordWrap"/>
                <Label x:Name="CopyrightLabel"
                       Text="© 2026 Recipe App"
                       FontSize="10"
                       TextColor="Gray"
                       HorizontalOptions="Center"
                       Margin="0,10,0,0"/>
            </VerticalStackLayout>
        </Frame>

    </VerticalStackLayout>
</ContentPage>