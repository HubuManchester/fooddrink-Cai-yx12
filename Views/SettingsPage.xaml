<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="RecipeRandomizer.Views.SettingsPage"
             Title="Settings">

    <VerticalStackLayout Padding="20" Spacing="20">

        <Label x:Name="TitleLabel"
               Text="⚙️ Accessibility Settings"
               FontSize="20"
               FontAttributes="Bold"
               HorizontalOptions="Center"/>

        <Frame x:Name="SettingsFrame" Padding="15" CornerRadius="12">
            <VerticalStackLayout Spacing="15">

                <Grid ColumnDefinitions="*,Auto">
                    <VerticalStackLayout>
                        <Label x:Name="LargeTextLabel"
                               Text="🔤 Large Text Mode"
                               FontSize="16"
                               FontAttributes="Bold"/>
                        <Label Text="Increase text size for better readability"
                               FontSize="12"
                               TextColor="Gray"/>
                    </VerticalStackLayout>
                    <Switch x:Name="LargeTextSwitch"
                            Grid.Column="1"
                            VerticalOptions="Center"/>
                </Grid>

                <BoxView HeightRequest="1" Color="#E0E0E0"/>

                <Grid ColumnDefinitions="*,Auto">
                    <VerticalStackLayout>
                        <Label x:Name="DarkModeLabel"
                               Text="🌙 Dark Mode"
                               FontSize="16"
                               FontAttributes="Bold"/>
                        <Label Text="Switch to dark theme"
                               FontSize="12"
                               TextColor="Gray"/>
                    </VerticalStackLayout>
                    <Switch x:Name="DarkThemeSwitch"
                            Grid.Column="1"
                            VerticalOptions="Center"/>
                </Grid>

            </VerticalStackLayout>
        </Frame>

        <Label x:Name="PreviewLabel"
               Text="Preview text size"
               FontSize="14"
               HorizontalOptions="Center"
               Margin="0,20,0,0"/>

    </VerticalStackLayout>
</ContentPage>